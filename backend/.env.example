# Local dev/test only. Use `db` as host inside the agent sandbox
# (docker/agent-sandbox/docker-compose.yml in the private agent repo), or
# `localhost` when running uvicorn directly against infra/docker-compose.yml.
# Production uses the real Supabase connection string, set via Cloud Run secrets.
DATABASE_URL=postgresql://postgres:postgres@db:5432/sms_ingest

# Tink HPKE keyset material (JSON). Generate locally; never commit real values.
TINK_PRIVATE_KEYSET_JSON=
TINK_PUBLIC_KEYSET_JSON=
SERVER_KEY_ID=

# Symmetric key for encrypting sensitive SMS fields before Postgres storage.
FIELD_ENCRYPTION_KEY=

# Pepper appended before hashing device bearer tokens.
TOKEN_HASH_PEPPER=

RETENTION_DAYS=90

# Required only for admin CLI provisioning (create-device, rotate-token) — the
# running server treats it as optional. Not a secret; not in Secret Manager. See
# projects/sms-ingest/links.md (private agent repo) for the current value.
API_BASE_URL=
